# Backend Environment Configuration
# Copy this file to .env and update values for your environment

# Server Configuration
PORT=3001
NODE_ENV=development
BACKEND_URL=http://localhost:3001

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
JWT_EXPIRES_IN=24h

# Database Configuration
# For development, use in-memory database (no setup needed)
# For production, set up PostgreSQL, MongoDB, or other database
DATABASE_TYPE=in-memory
DATABASE_URL=sqlite:./dev.db

# Optional: Logging
LOG_LEVEL=debug

# Optional: Email (for future password reset functionality)
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@boldtap.com
