# Backend Environment Configuration
# Copy this file to .env and update values for your environment

# ============ SERVER CONFIGURATION ============
PORT=3001
NODE_ENV=development
BACKEND_URL=http://localhost:3001

# ============ FRONTEND CONFIGURATION ============
FRONTEND_URL=http://localhost:3000
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/auth/reset-password
FRONTEND_VERIFY_EMAIL_URL=http://localhost:3000/auth/verify-email

# ============ SECURITY & JWT CONFIGURATION ============
# IMPORTANT: Generate a secure JWT secret for production!
# Run: openssl rand -hex 64
# Or: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRY=7d

# ============ DATABASE CONFIGURATION (PostgreSQL) ============
# For cloud-managed PostgreSQL, use DATABASE_URL directly
# For local PostgreSQL with individual fields:
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=boldtap
DATABASE_USER=postgres
DATABASE_PASSWORD=your-secure-password
# OR provide full connection string:
# DATABASE_URL=postgresql://user:password@host:5432/boldtap

# ============ EMAIL CONFIGURATION (SendGrid) ============
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx
SMTP_FROM_EMAIL=noreply@boldtap.com
SMTP_FROM_NAME=BoldTap

# ============ OAUTH CONFIGURATION ============
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# ============ STRIPE CONFIGURATION ============
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Stripe Product Pricing IDs (created in Stripe Dashboard)
# https://dashboard.stripe.com/prices
STRIPE_PRICE_STARTER=price_xxxxx
STRIPE_PRICE_PRO=price_xxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxx

# ============ RATE LIMITING CONFIGURATION ============
# Rate limit window (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window (general endpoints)
RATE_LIMIT_MAX_REQUESTS=100
# Max requests per window (auth endpoints - stricter)
RATE_LIMIT_AUTH_MAX_REQUESTS=12

# ============ OPTIONAL CONFIGURATION ============
# Logging
LOG_LEVEL=debug
